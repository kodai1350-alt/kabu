{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "tvly-xxxxxxxxxxxx"
      }
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
      }
    },
    "financial-datasets": {
      "type": "http",
      "url": "https://mcp.financialdatasets.ai/mcp",
      "headers": {
        "X-API-KEY": "xxxxxxxxxxxx"
      }
    }
  }
}
